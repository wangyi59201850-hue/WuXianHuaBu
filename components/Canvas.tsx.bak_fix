      <div className="absolute left-3 top-1/2 z-20 flex -translate-y-1/2 flex-col items-stretch gap-1.5 rounded-xl border border-white/10 bg-zinc-900/85 p-1.5 shadow-lg backdrop-blur">
        <button
          className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
          onClick={() => onGoHome?.()}
          title="杩斿洖棣栭〉鍚姩椤?
        >
          <House className="h-4 w-4" />
          <span>棣栭〉</span>
        </button>
        <div className="relative">
          <button
            className="inline-flex h-9 w-full items-center justify-center rounded-lg bg-white px-2 text-sm font-bold text-zinc-900 ring-1 ring-white/80 transition-colors hover:bg-cyan-100"
            onClick={() => {
              setCreatePanelAnchor("button");
              setCreatePanelPoint(null);
              setCreatePanelOpen((v) => !v);
            }}
            title="鏂板"
          >
            <Plus className="h-4 w-4" />
          </button>
          {createPanelOpen && createPanelAnchor === "button" ? (
            <div
              className="absolute left-full top-0 z-30 ml-2 flex min-w-[104px] flex-col gap-1.5 rounded-xl border border-white/15 bg-zinc-900/95 p-1.5 shadow-xl backdrop-blur"
            >
              <button
                className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
                onClick={() => {
                  createPromptNodeWithOutput();
                  setCreatePanelOpen(false);
                }}
                title="鍦ㄦ寚閽堥檮杩戞坊鍔犲浘鐗囩敓鎴愯妭鐐?
              >
                <ImageIcon className="h-4 w-4" />
                <span>鐢熷浘</span>
              </button>
              <button
                className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
                onClick={() => {
                  createPromptNode2WithOutput();
                  setCreatePanelOpen(false);
                }}
                title="鍦ㄦ寚閽堥檮杩戞坊鍔犺棰戠敓鎴愯妭鐐?
              >
                <Video className="h-4 w-4" />
                <span>鐢熻棰?/span>
              </button>
              <button
                className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
                onClick={() => {
                  createEmptyLocalImageNode();
                  setCreatePanelOpen(false);
                }}
                title="鍦ㄧ敾甯冩柊寤虹┖鐧界礌鏉愯妭鐐癸紙鍙屽嚮鍔犺浇鍥剧墖锛?
              >
                <Upload className="h-4 w-4" />
                <span>绱犳潗</span>
              </button>
            </div>
          ) : null}
        </div>
        <button
          className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
          onClick={() => setMediaHistoryOpen(true)}
          title="鍘嗗彶璁板綍锛氭寜鏃ユ湡鏌ョ湅鎴愮墖锛屾偓鍋滅湅鍙傛暟锛岀紪杈戣浇鍏ョ敾甯?
        >
          <Images className="h-4 w-4" />
          <span>鍘嗗彶</span>
        </button>
        <button
          className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
          onClick={autoLayoutNodes}
          title="鑷姩鎺掔増瀵归綈鑺傜偣"
        >
          <LayoutGrid className="h-4 w-4" />
          <span>鎺掔増</span>
        </button>
        <button
          className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
          onClick={() => void openCacheSettings()}
          title="缂撳瓨鐩綍璁剧疆"
        >
          <Settings className="h-4 w-4" />
          <span>璁剧疆</span>
        </button>
      </div>
      {createPanelOpen && createPanelAnchor === "context" && createPanelPoint ? (
        <div
          className="fixed z-40 flex min-w-[104px] flex-col gap-1.5 rounded-xl border border-white/15 bg-zinc-900/95 p-1.5 shadow-xl backdrop-blur"
          style={{ left: `${createPanelPoint.x}px`, top: `${createPanelPoint.y}px` }}
        >
          <button
            className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
            onClick={() => {
              createPromptNodeWithOutput();
              setCreatePanelOpen(false);
            }}
            title="鍦ㄦ寚閽堥檮杩戞坊鍔犲浘鐗囩敓鎴愯妭鐐?
          >
            <ImageIcon className="h-4 w-4" />
            <span>鐢熷浘</span>
          </button>
          <button
            className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
            onClick={() => {
              createPromptNode2WithOutput();
              setCreatePanelOpen(false);
            }}
            title="鍦ㄦ寚閽堥檮杩戞坊鍔犺棰戠敓鎴愯妭鐐?
          >
            <Video className="h-4 w-4" />
            <span>鐢熻棰?/span>
          </button>
          <button
            className="inline-flex h-9 items-center gap-1.5 rounded-lg bg-white/5 px-2 text-xs text-white ring-1 ring-white/10 hover:bg-cyan-500/15"
            onClick={() => {
              createEmptyLocalImageNode();
              setCreatePanelOpen(false);
            }}
            title="鍦ㄧ敾甯冩柊寤虹┖鐧界礌鏉愯妭鐐癸紙鍙屽嚮鍔犺浇鍥剧墖锛?
          >
            <Upload className="h-4 w-4" />
            <span>绱犳潗</span>
          </button>
        </div>
      ) : null}
    </div>
  );
}
