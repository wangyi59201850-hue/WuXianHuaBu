      });
      const j = await r.json().catch(() => ({}));
      if (!r.ok) {
        setLoginDiagErr(typeof j?.error === "string" ? j.error : "鎵撳紑鐩綍澶辫触");
      }
    } catch (e) {
      setLoginDiagErr(e instanceof Error ? e.message : String(e));
    } finally {
      setLoginDiagBusy(null);
    }
