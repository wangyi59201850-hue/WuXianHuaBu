      });
      const j = await r.json().catch(() => ({}));
      if (!r.ok || !j?.ok) {
        if (j?.cancelled) return;
        setCacheOnboardingErr(typeof j?.error === "string" ? j.error : "閫夋嫨鐩綍澶辫触");
        return;
